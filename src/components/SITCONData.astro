---
interface Data {
	progress: number;
	value: number;
	prefix: string;
	suffix: string;
}

const data: Data[] = [
	{ progress: 0, value: 0, prefix: "起點", suffix: "萌芽期" },
	{ progress: 0.3, value: 400, prefix: "寬頻", suffix: "元年" },
	{ progress: 0.7, value: 1600, prefix: "行動", suffix: "爆發" },
	{ progress: 1.0, value: 2100, prefix: "全民", suffix: "上網" }
];

const scrollHeight = 600;
const first = data[0];
---

<div class="sc-container" style={`height: ${scrollHeight}vh`}>
	<div class="sc-sticky">
		<div class="sc-progress-bar">
			<div class="sc-progress-fill"></div>
		</div>

		<div class="sc-prefix">{first.prefix}</div>

		<div class="sc-center">
			<div class="sc-tick-line"></div>
			<div class="sc-number">{first.value.toLocaleString()}</div>
			<div class="sc-rule"></div>
		</div>

		<div class="sc-suffix">{first.suffix}</div>

		<!-- 節點導航箭頭 -->
		<button class="sc-nav sc-nav--prev" aria-label="上一個節點">&#8593;</button>
		<button class="sc-nav sc-nav--next" aria-label="下一個節點">&#8595;</button>
	</div>
</div>

<script define:vars={{ data }}>
	// 節點附近的「停駐半徑」（佔總進度的比例）
	// 在此範圍內數字會鎖定為節點精確值，不插值
	const DWELL = 0.05;

	function lerp(a, b, t) {
		return a + (b - a) * t;
	}

	function getState(progress) {
		// 落在某節點的停駐區間 → 鎖定精確值
		const dwellNode = data.find(k => Math.abs(k.progress - progress) < DWELL);
		if (dwellNode) return { ...dwellNode };

		if (progress <= data[0].progress) return { ...data[0] };
		const last = data.length - 1;
		if (progress >= data[last].progress) return { ...data[last] };

		const nextIdx = data.findIndex(k => k.progress >= progress);
		const prevIdx = nextIdx - 1;
		const prev = data[prevIdx];
		const next = data[nextIdx];
		const t = (progress - prev.progress) / (next.progress - prev.progress);
		const src = t > 0.5 ? next : prev;

		return {
			value: lerp(prev.value, next.value, t),
			prefix: src.prefix,
			suffix: src.suffix
		};
	}

	function getProgressFromValue(value) {
		if (value <= data[0].value) return 0;
		const last = data[data.length - 1];
		if (value >= last.value) return 1;
		const next = data.find(k => k.value >= value);
		const prev = data[data.indexOf(next) - 1];
		if (!prev) return 0;
		const t = (value - prev.value) / (next.value - prev.value);
		return prev.progress + t * (next.progress - prev.progress);
	}

	document.querySelectorAll(".sc-container").forEach(container => {
		const progressFill = container.querySelector(".sc-progress-fill");
		const numberEl = container.querySelector(".sc-number");
		const prefixEl = container.querySelector(".sc-prefix");
		const suffixEl = container.querySelector(".sc-suffix");
		const btnPrev = container.querySelector(".sc-nav--prev");
		const btnNext = container.querySelector(".sc-nav--next");

		let targetValue = 0;
		let displayedValue = 0;
		let currentState = getState(0);
		let currentProgress = 0;

		// ── 捲動到指定節點 ──────────────────────────
		function scrollToNode(idx) {
			const clamped = Math.max(0, Math.min(data.length - 1, idx));
			const scrollable = container.offsetHeight - window.innerHeight;
			const offsetTop = container.getBoundingClientRect().top + window.scrollY;
			const targetY = offsetTop + data[clamped].progress * scrollable;
			window.scrollTo({ top: targetY, behavior: "smooth" });
		}

		// 找到目前最近的節點 index
		function nearestNodeIdx() {
			let minDist = Infinity,
				idx = 0;
			data.forEach((k, i) => {
				const d = Math.abs(k.progress - currentProgress);
				if (d < minDist) {
					minDist = d;
					idx = i;
				}
			});
			return idx;
		}

		btnPrev.addEventListener("click", () => scrollToNode(nearestNodeIdx() - 1));
		btnNext.addEventListener("click", () => scrollToNode(nearestNodeIdx() + 1));

		// ── 箭頭顯示狀態（頭尾停用）─────────────────
		function updateNavState() {
			const idx = nearestNodeIdx();
			btnPrev.disabled = idx === 0;
			btnNext.disabled = idx === data.length - 1;
		}

		// ── 文字切換 ─────────────────────────────────
		function swapText(el, newText) {
			if (!el || el._currentText === newText) return;
			el._currentText = newText;
			el.classList.remove("sc-swap-in", "sc-swap-out");
			void el.offsetWidth;
			el.classList.add("sc-swap-out");
			setTimeout(() => {
				el.textContent = newText;
				el.classList.remove("sc-swap-out");
				el.classList.add("sc-swap-in");
				setTimeout(() => el.classList.remove("sc-swap-in"), 400);
			}, 280);
		}

		// ── Scroll handler ───────────────────────────
		function onScroll() {
			const rect = container.getBoundingClientRect();
			const scrollable = container.offsetHeight - window.innerHeight;
			currentProgress = Math.max(0, Math.min(1, -rect.top / scrollable));

			currentState = getState(currentProgress);
			targetValue = Math.round(currentState.value);
			progressFill.style.width = currentProgress * 100 + "%";
			updateNavState();
		}

		// ── rAF 主循環 ───────────────────────────────
		function tick() {
			requestAnimationFrame(tick);

			if (displayedValue !== targetValue) {
				const diff = targetValue - displayedValue;
				const step = Math.sign(diff) * Math.max(1, Math.floor(Math.abs(diff) * 0.12));
				displayedValue += step;
				if (diff > 0 && displayedValue > targetValue) displayedValue = targetValue;
				if (diff < 0 && displayedValue < targetValue) displayedValue = targetValue;
				numberEl.textContent = displayedValue.toLocaleString();
			}

			const textState = getState(getProgressFromValue(displayedValue));
			swapText(prefixEl, textState.prefix);
			swapText(suffixEl, textState.suffix);
		}

		window.addEventListener("scroll", onScroll, { passive: true });
		onScroll();
		tick();
	});
</script>

<style>
	.sc-container {
		position: relative;
	}

	.sc-sticky {
		position: sticky;
		top: 0;
		height: 100vh;
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		align-items: center;
		gap: 2rem;
		padding: 0 5vw;
		overflow: hidden;
		background-image: linear-gradient(#1e1e2e 1px, transparent 1px), linear-gradient(90deg, #1e1e2e 1px, transparent 1px);
		background-size: 80px 80px;
	}

	.sc-sticky::after {
		content: "";
		position: absolute;
		inset: 0;
		background: radial-gradient(ellipse 70% 70% at 50% 50%, transparent 40%, var(--sc-bg, #0a0a0f) 100%);
		pointer-events: none;
	}

	.sc-progress-bar {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		height: 2px;
		background: #1e1e2e;
		z-index: 10;
	}
	.sc-progress-fill {
		height: 100%;
		width: 0%;
		background: linear-gradient(90deg, #7eb8c9, #e8d5a3);
		transition: width 0.05s linear;
	}

	.sc-prefix,
	.sc-suffix {
		position: relative;
		z-index: 5;
		font-size: clamp(1rem, 2vw, 1.5rem);
		color: #e8d5a3;
		line-height: 1.5;
	}
	.sc-prefix {
		text-align: right;
	}
	.sc-suffix {
		text-align: left;
	}

	:global(.sc-swap-out) {
		animation: sc-out 0.3s ease forwards;
	}
	:global(.sc-swap-in) {
		animation: sc-in 0.35s ease forwards;
	}
	@keyframes sc-out {
		to {
			opacity: 0;
			transform: translateY(-8px);
		}
	}
	@keyframes sc-in {
		from {
			opacity: 0;
			transform: translateY(8px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.sc-center {
		position: relative;
		z-index: 5;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.5rem;
		min-width: 18rem;
	}
	.sc-tick-line {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		width: 1px;
		height: calc(100% + 3rem);
		background: linear-gradient(to bottom, transparent, #3a3a52 30%, #3a3a52 70%, transparent);
		z-index: -1;
		pointer-events: none;
	}
	.sc-number {
		font-weight: 700;
		font-size: clamp(3.5rem, 10vw, 7rem);
		color: #ffffff;
		letter-spacing: -0.03em;
		line-height: 1;
		font-variant-numeric: tabular-nums;
		transition: color 0.5s;
	}
	.sc-rule {
		width: 100%;
		height: 1px;
		background: linear-gradient(90deg, transparent, #3a3a52, transparent);
		margin: 0.2rem 0;
	}
	/* 導航箭頭 */
	.sc-nav {
		position: absolute;
		right: 5vw;
		z-index: 10;
		width: 2rem;
		height: 2rem;
		display: flex;
		align-items: center;
		justify-content: center;
		background: none;
		border: 1px solid #3a3a52;
		border-radius: 4px;
		color: #555570;
		font-size: 0.85rem;
		cursor: pointer;
		transition:
			border-color 0.2s,
			color 0.2s;
	}
	.sc-nav:hover:not(:disabled) {
		border-color: #e8d5a3;
		color: #e8d5a3;
	}
	.sc-nav:disabled {
		opacity: 0.2;
		cursor: default;
	}
	.sc-nav--prev {
		bottom: calc(50% + 2.8rem);
	}
	.sc-nav--next {
		top: calc(50% + 2.8rem);
	}

	@media (max-width: 600px) {
		.sc-sticky {
			grid-template-columns: 1fr;
			grid-template-rows: auto auto auto;
			justify-items: center;
			padding: 3rem 1.5rem;
			gap: 1.5rem;
		}
		.sc-prefix,
		.sc-suffix {
			text-align: center;
		}
		.sc-number {
			font-size: 4.5rem;
		}
	}
</style>
