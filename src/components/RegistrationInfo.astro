---
import { Image } from "astro:assets";
import registrationPhoto from "@/assets/registration/registration-photo.png";
import CalendarIcon from "~icons/ic/baseline-calendar-month";
import TicketIcon from "~icons/ic/baseline-confirmation-number";
import SchoolIcon from "~icons/ic/baseline-school";

const cards = [
	{
		title: "活動日期",
		main: "2026/07/21 – 07/25",
		note: "共五天四夜",
		icon: CalendarIcon
	},
	{
		title: "晚鳥票報名日期",
		main: "2026/06/01 – 06/30",
		note: "逾期不候",
		icon: TicketIcon,
		iconClass: "rotate-[-12deg]"
	},
	{
		title: "活動地點",
		main: "台灣大學",
		note: "詳細地點待公告",
		icon: SchoolIcon
	}
];

const noticeItems = [
	[{ text: "第 5 人（含）起將以原價計費。" }],
	[{ text: "提前一晚入住營隊 700 NTD/人" }],
	[{ text: "若在 5/11（日）23:59 前報名即享有早鳥價，享有早鳥價者仍可享有團報優惠。" }],
	[
		{ text: "團體報名不保證全數錄取，團體報名凡錄取者（無論是否全數錄取）皆享有團報優惠價格，詳見" },
		{
			text: "《報名簡章》",
			href: "https://drive.google.com/file/d/1nxt-lYWAMnsK-QbwbbeIV7lTi9hcimTw/view"
		},
		{ text: "。" }
	],
	[{ text: "本次夏令營預計招收學員 54 名，我們會針對報名資料做簡易審查，非先報先錄取。" }],
	[{ text: "正取學員名單最晚將於 6/8（日）前公佈，屆時請關注 SITCON 相關社群媒體及 Email 信箱。" }],
	[
		{ text: "正取學員需完成報名費繳交，始完成報名程序；另設有補助名額，請詳閱" },
		{
			text: "《報名費用補助辦法》",
			href: "https://drive.google.com/file/d/1g6OSBT0yZIpOjKk5tkzgFOv-mcpBrPLd/view"
		},
		{ text: "。" }
	],
	[
		{ text: "關於退費事宜，請見" },
		{
			text: "《退費說明文件》",
			href: "https://drive.google.com/file/d/1A193ekw7DtCgfMmxsICeT4gO2pWYGd4q/view"
		},
		{ text: "。" }
	]
];
---

<div class="overflow-hidden">
	<svg id="reg-transition" viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" class="block w-full" aria-hidden="true"></svg>
</div>

<section
	class="bg-foreground px-[clamp(1.25rem,8.5vw,8rem)] pt-[var(--gap)] pb-[var(--gap)] text-white"
	style="--row-h: clamp(48px, 5.4vw, 82px); --radius: clamp(28px, 4.2vw, 64px); --gap: clamp(24px, 4.2vw, 64px); --label-size: clamp(17px, 2.1vw, 32px); --heading-size: clamp(1.65rem, 3.25vw, 2.5rem)"
>
	<div class="bg-green flex w-fit items-center justify-center gap-[10px] p-2.5">
		<span class="text-foreground leading-none font-bold" style="font-size: var(--heading-size)">報名資訊</span>
	</div>

	<!-- 三張資訊卡 -->
	<div class="grid w-full grid-cols-1 md:grid-cols-3" style="margin-top: var(--gap); gap: var(--gap)">
		{
			cards.map(({ title, main, note, icon: Icon, iconClass = "" }) => (
				<div class="bg-soft-blue relative mx-auto aspect-[375/260] w-full max-w-[24rem] min-w-0 overflow-hidden md:aspect-[375/318] md:max-w-none" style="border-radius: var(--radius) 0">
					<span class="text-background absolute top-[15.7%] left-[8.4%] text-[clamp(1rem,1.45vw,1.25rem)] leading-none font-bold">{title}</span>
					<span class="text-background absolute top-[28%] left-[8.4%] max-w-[78%] text-[clamp(1.25rem,2vw,1.75rem)] leading-[160%] font-bold">{main}</span>
					<Icon class={`text-background/30 absolute top-[46%] right-[-6%] h-auto w-[44%] md:top-[52%] md:right-auto md:left-[60%] md:w-[50%] ${iconClass}`} />
					<span class="text-background absolute top-[77.4%] left-[8.4%] text-base leading-[160%] font-bold">{note}</span>
				</div>
			))
		}
	</div>

	<div class="flex w-full flex-col items-start lg:flex-row" style="margin-top: var(--gap)">
		<!-- 組合卡片：--row-h 統一控制，Object 1 = 5× row，其餘 1× row -->
		<div class="flex w-full flex-col items-start lg:flex-[691]">
			{
				[
					{
						label: "早鳥優惠",
						color: "text-orange",
						price: "1000元/人",
						tl: true,
						br: false
					},
					{
						label: "一人報名",
						color: "text-primary-blue",
						price: "1500元/人",
						tl: false,
						br: false
					},
					{
						label: "兩人報名",
						color: "text-soft-blue",
						price: "1200元/人",
						tl: false,
						br: false
					},
					{
						label: "三人報名",
						color: "text-sky-blue",
						price: "1000元/人",
						tl: false,
						br: false
					},
					{
						label: "早鳥優惠",
						color: "text-dark-green",
						price: "800元/人",
						tl: false,
						br: true
					}
				].map(({ label, color, price, tl, br }) => (
					<div
						class="bg-background grid w-full grid-cols-2 items-center border-y border-black px-[9.262%]"
						style={`height: var(--row-h); ${tl ? "border-top-left-radius: var(--radius);" : ""}${br ? "border-bottom-right-radius: var(--radius);" : ""}`}
					>
						<span class={`text-center leading-[150%] font-extrabold ${color}`} style="font-size: var(--label-size)">
							{label}
						</span>
						<span class="text-center leading-[150%] font-extrabold text-black" style="font-size: var(--label-size)">
							{price}
						</span>
					</div>
				))
			}
		</div>

		<div class="relative mt-[var(--gap)] aspect-[565/410] w-full overflow-hidden lg:mt-0 lg:flex-[565]">
			<Image src={registrationPhoto} alt="SITCON Camp 活動照片" class="absolute top-[6.585%] left-[7.434%] aspect-[239/159] w-[85.133%] object-cover" loading="lazy" decoding="async" />
			<a
				href="#"
				class="bg-green absolute bottom-[4.878%] left-[35.929%] flex h-[clamp(3rem,17.561%,4.5rem)] items-center justify-center rounded-2xl px-3 text-[clamp(1.125rem,2.25vw,2.125rem)] leading-[150%] font-extrabold text-white shadow-[clamp(4px,0.53vw,8px)_clamp(4px,0.53vw,8px)_0_0_#F69977]"
			>
				立即報名
			</a>
		</div>
	</div>

	<div class="bg-orange flex w-fit items-center justify-center gap-[10px] p-2.5" style="margin-top: var(--gap)">
		<span class="text-foreground leading-none font-bold" style="font-size: var(--heading-size)">注意事項</span>
	</div>

	<ol class="mt-6 list-decimal space-y-1 pl-6 text-[clamp(1rem,1.25vw,1.125rem)] leading-[170%] font-bold text-white">
		{
			noticeItems.map(item => (
				<li>
					{item.map(part =>
						"href" in part ? (
							<a class="underline" href={part.href} target="_blank" rel="noreferrer">
								{part.text}
							</a>
						) : (
							part.text
						)
					)}
				</li>
			))
		}
	</ol>
</section>

<!-- 底部過渡：對角線斜切，上=foreground 下=background -->
<div class="overflow-hidden">
	<svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" class="block w-full" aria-hidden="true">
		<!-- 上方三角形：foreground -->
		<polygon points="0,0 1440,0 0,80" fill="#24272e"></polygon>
		<!-- 下方三角形：background -->
		<polygon points="1440,0 1440,80 0,80" fill="#f9f5ef"></polygon>
	</svg>
</div>

<script>
	const svg = document.getElementById("reg-transition")!;
	const ns = "http://www.w3.org/2000/svg";
	const W = 1440,
		H = 60;
	const COUNT = 8;
	const COLOR = "#24272e";

	function rand(min: number, max: number) {
		return Math.random() * (max - min) + min;
	}

	// 底部矩形確保無縫銜接
	const rect = document.createElementNS(ns, "rect");
	rect.setAttribute("x", "0");
	rect.setAttribute("y", String(H * 0.75));
	rect.setAttribute("width", String(W));
	rect.setAttribute("height", String(H));
	rect.setAttribute("fill", COLOR);
	svg.appendChild(rect);

	// 隨機橢圓，分 slot 確保分佈均勻
	const slotW = W / COUNT;
	for (let i = 0; i < COUNT; i++) {
		const el = document.createElementNS(ns, "ellipse");
		el.setAttribute("cx", String(slotW * i + rand(slotW * 0.1, slotW * 0.9)));
		el.setAttribute("cy", String(H));
		el.setAttribute("rx", String(rand(140, 230)));
		el.setAttribute("ry", String(rand(30, 50)));
		el.setAttribute("fill", COLOR);
		svg.appendChild(el);
	}
</script>
