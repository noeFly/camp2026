---
import { Menu } from "@lucide/astro";
import SitconCampLogo from "@/assets/SITCONCampLogo.svg";

const navItems = [
  { label: "報名資訊", href: "/#registration-info" },
  { label: "主線課程", href: "/course/" },
  { label: "課程活動", href: "/#course-events" },
  { label: "籌備團隊", href: "/about/" },
  { label: "FAQ", href: "/#faq" },
];
---

<header class="site-header" data-site-header aria-label="SITCON Camp 2026">
  <a class="site-header__brand" href="/" aria-label="SITCON Camp 2026 首頁">
    <img
      class="site-header__logo"
      src={SitconCampLogo.src}
      width={SitconCampLogo.width}
      height={SitconCampLogo.height}
      alt="SITCON Camp 2026"
    />
  </a>

  <nav class="site-header__nav" aria-label="主要導覽">
    {
      navItems.map((item) => (
        <a class="site-header__link" href={item.href}>
          {item.label}
        </a>
      ))
    }
  </nav>

  <a class="site-header__cta" href="/#registration-info">立即報名</a>

  <details class="site-header__mobile-menu">
    <summary class="site-header__mobile-trigger" aria-label="開啟主要導覽">
      <Menu size={30} stroke-width={3} aria-hidden="true" />
    </summary>
    <nav class="site-header__mobile-nav" aria-label="主要導覽">
      {
        navItems.map((item) => (
          <a class="site-header__mobile-link" href={item.href}>
            {item.label}
          </a>
        ))
      }
      <a class="site-header__mobile-cta" href="/#registration-info">
        立即報名
      </a>
    </nav>
  </details>
</header>

<script>
  const siteHeader = document.querySelector<HTMLElement>("[data-site-header]");

  if (siteHeader) {
    const revealHeader = () => {
      siteHeader.classList.add("is-visible");
    };
    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    const heroIntro = document.querySelector<HTMLElement>("[data-hero-intro]");
    const shouldWaitForHeroIntro =
      document.documentElement.classList.contains("hero-intro-lock") ||
      Boolean(heroIntro && !heroIntro.hidden);

    if (prefersReducedMotion) {
      revealHeader();
    } else if (shouldWaitForHeroIntro) {
      window.addEventListener("hero-intro:finished", revealHeader, {
        once: true,
      });
    } else {
      requestAnimationFrame(() => {
        window.setTimeout(revealHeader, 120);
      });
    }
  }
</script>

<style>
  .site-header {
    position: fixed;
    inset-block-start: clamp(0.45rem, 1vw, 0.8rem);
    inset-inline: clamp(0.45rem, 1vw, 0.8rem);
    z-index: 1000;
    box-sizing: border-box;
    display: flex;
    align-items: center;
    gap: clamp(0.85rem, 1.45vw, 1.8rem);
    min-height: clamp(3.9rem, 5.1vw, 5.9rem);
    padding: clamp(0.55rem, 0.9vw, 1rem) clamp(1.05rem, 2.2vw, 2.25rem);
    color: var(--color-background);
    background: var(--color-foreground);
    border-radius: clamp(1.1rem, 1.7vw, 1.75rem);
    opacity: 0;
    transform: translateY(calc(-100% - 1rem));
    transition:
      opacity 220ms ease,
      transform 560ms cubic-bezier(0.22, 1, 0.36, 1);
    will-change: transform, opacity;
  }

  .site-header.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .site-header__brand {
    display: inline-flex;
    align-items: center;
    flex: 0 0 auto;
    color: inherit;
    text-decoration: none;
  }

  .site-header__logo {
    display: block;
    width: clamp(7.4rem, 7.7vw, 8.4rem);
    height: auto;
  }

  .site-header__nav {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: clamp(0.85rem, 1.45vw, 1.8rem);
    margin-inline-start: auto;
  }

  .site-header__link,
  .site-header__cta,
  .site-header__mobile-link,
  .site-header__mobile-cta {
    color: inherit;
    font-weight: 800;
    letter-spacing: 0;
    line-height: 1.1;
    text-decoration: none;
    white-space: nowrap;
  }

  .site-header__link {
    font-size: clamp(0.95rem, 1.15vw, 1.35rem);
    transition:
      color 160ms ease,
      transform 160ms ease;
  }

  .site-header__link:hover,
  .site-header__link:focus-visible {
    color: var(--color-soft-blue);
    transform: translateY(-0.08rem);
  }

  .site-header__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: clamp(2.45rem, 2.75vw, 3.2rem);
    padding: 0 clamp(1rem, 1.55vw, 1.7rem);
    color: var(--color-foreground);
    background: var(--color-soft-blue);
    border-radius: clamp(0.8rem, 1.1vw, 1.15rem);
    font-size: clamp(1rem, 1.25vw, 1.45rem);
    transition:
      background 160ms ease,
      transform 160ms ease;
  }

  .site-header__cta:hover,
  .site-header__cta:focus-visible,
  .site-header__mobile-cta:hover,
  .site-header__mobile-cta:focus-visible {
    background: var(--color-sky-blue);
    transform: translateY(-0.08rem);
  }

  .site-header__link:focus-visible,
  .site-header__cta:focus-visible,
  .site-header__mobile-trigger:focus-visible,
  .site-header__mobile-link:focus-visible,
  .site-header__mobile-cta:focus-visible {
    outline: 0.16rem solid var(--color-background);
    outline-offset: 0.2rem;
  }

  .site-header__mobile-menu {
    display: none;
    margin-inline-start: auto;
  }

  .site-header__mobile-trigger {
    display: inline-grid;
    place-items: center;
    width: 3.4rem;
    aspect-ratio: 1;
    color: var(--color-background);
    cursor: pointer;
    list-style: none;
    border-radius: 999rem;
  }

  .site-header__mobile-trigger::-webkit-details-marker {
    display: none;
  }

  .site-header__mobile-nav {
    position: absolute;
    inset-block-start: calc(100% + 0.55rem);
    inset-inline: 0;
    display: grid;
    gap: 0.4rem;
    padding: 1rem;
    color: var(--color-background);
    background: var(--color-foreground);
    border-radius: 1.2rem;
  }

  .site-header__mobile-link,
  .site-header__mobile-cta {
    min-height: 3rem;
    padding: 0.9rem 1rem;
    border-radius: 0.8rem;
    font-size: 1.125rem;
  }

  .site-header__mobile-link:hover,
  .site-header__mobile-link:focus-visible {
    color: var(--color-soft-blue);
  }

  .site-header__mobile-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--color-foreground);
    background: var(--color-soft-blue);
  }

  @media (max-width: 72rem) {
    .site-header {
      min-height: 4.1rem;
      padding: 0.75rem 1rem;
      border-radius: 1.25rem;
    }

    .site-header__logo {
      width: clamp(6.6rem, 24vw, 7.8rem);
    }

    .site-header__nav,
    .site-header__cta {
      display: none;
    }

    .site-header__mobile-menu {
      display: block;
    }
  }

  @media (max-width: 28rem) {
    .site-header {
      inset-block-start: 0.35rem;
      inset-inline: 0.35rem;
      min-height: 3.75rem;
      padding: 0.65rem 0.8rem;
      border-radius: 1rem;
    }

    .site-header__logo {
      width: min(7rem, 50vw);
    }

    .site-header__mobile-trigger {
      width: 2.75rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .site-header {
      transition: none;
      opacity: 1;
      transform: none;
    }
  }
</style>

<noscript>
  <style>
    .site-header {
      opacity: 1 !important;
      transform: none !important;
    }
  </style>
</noscript>
