---
import { Image, getImage } from "astro:assets";
import organizers from "../data/organizers.json";

import { X } from "@lucide/astro";

type Org = {
	name: string;
	role?: string;
	description?: string;
	iconPath: string;
	url?: string;
};

const isOrg = (v: unknown): v is Org => {
	if (typeof v !== "object" || v === null) return false;
	const r = v as Record<string, unknown>;
	return typeof r.name === "string" && typeof r.iconPath === "string";
};

const sponsorGlob = import.meta.glob<{ default: ImageMetadata }>("../assets/sponsors/*", { eager: true });

function getMeta(iconPath: string): ImageMetadata | undefined {
	const file = iconPath.split("/").pop();
	return sponsorGlob[`../assets/sponsors/${file}`]?.default;
}

type ResolvedOrg = Org & { meta?: ImageMetadata; popoverSrc: string };

async function resolve(org: Org): Promise<ResolvedOrg> {
	const meta = getMeta(org.iconPath);
	if (!meta) return { ...org, popoverSrc: org.iconPath };
	const { src } = await getImage({ src: meta });
	return { ...org, meta, popoverSrc: src };
}

const sections = await Promise.all(
	Object.entries(organizers)
		.map(([tag, items]): [string, Org[]] => [tag, (items as unknown[]).filter(isOrg)])
		.filter(([, list]) => list.length > 0)
		.map(async ([tag, items]) => [tag, await Promise.all(items.map(resolve))] as [string, ResolvedOrg[]])
);
---

{
	sections.map(([tag, items]) => (
		<section class="mx-64 my-32">
			<h1 class="mb-4 text-[48px] font-bold">{tag}</h1>
			<div class="flex flex-wrap items-center gap-x-8">
				{items.map(org => (
					<button
						type="button"
						data-icon-path={org.popoverSrc}
						data-name={org.name}
						data-role={org.role ?? ""}
						data-desc={org.description ?? ""}
						data-url={org.url ?? ""}
						aria-haspopup="dialog"
						aria-controls="org-popover"
						class="org-card group focus-visible:ring-primary-blue/50 cursor-pointer transition-transform hover:-translate-y-1 focus-visible:ring-2 focus-visible:outline-none"
					>
						{org.meta ? <Image src={org.meta} alt={org.name} class="h-32 w-auto object-contain" /> : <img src={org.iconPath} alt={org.name} class="h-32 w-auto object-contain" />}
					</button>
				))}
			</div>
		</section>
	))
}

<div id="org-popover" popover role="dialog" aria-labelledby="org-popover-title" class="org-popover m-auto w-full max-w-sm rounded-2xl border-0 p-0 shadow-2xl">
	<div class="relative flex flex-col items-center gap-4 px-6 pt-8 pb-6">
		<button
			type="button"
			popovertarget="org-popover"
			popovertargetaction="hide"
			class="text-foreground/35 hover:bg-orange/8 hover:text-foreground/70 absolute top-3 right-3 flex size-8 cursor-pointer items-center justify-center rounded-full border-none bg-transparent transition-all duration-150"
			aria-label="關閉"
		>
			<X size={18} stroke-width={1.5} />
		</button>

		<div class="flex flex-col items-center gap-3">
			<div class="flex h-36 w-full items-center justify-center rounded-2xl bg-white/70 p-4 shadow-sm">
				<img id="org-popover-icon" alt="" class="max-h-full max-w-full object-contain" />
			</div>
			<div class="text-center">
				<h3 id="org-popover-title" class="text-foreground text-xl font-bold"></h3>
				<p id="org-popover-role" class="text-foreground/50 mt-0.5 text-sm"></p>
			</div>
		</div>

		<p id="org-popover-desc" class="text-foreground/65 w-full rounded-xl px-4 py-3 text-center text-sm leading-relaxed"></p>

		<a
			id="org-popover-url"
			href="#"
			target="_blank"
			rel="noopener noreferrer"
			class="bg-blue w-full rounded-xl py-2.5 text-center text-sm font-semibold text-white no-underline transition-colors duration-150"
		>
			前往官網
		</a>
	</div>
</div>

<script>
	interface OrgDataset extends DOMStringMap {
		iconPath: string;
		name: string;
		role: string;
		desc: string;
		url: string;
	}

	function getEl<T extends HTMLElement = HTMLElement>(id: string): T {
		const el = document.getElementById(id);
		if (!el) throw new Error(`[org-popover] missing #${id}`);
		return el as T;
	}

	const popoverEl = getEl("org-popover");
	const icon = getEl<HTMLImageElement>("org-popover-icon");
	const title = getEl("org-popover-title");
	const roleEl = getEl("org-popover-role");
	const descEl = getEl("org-popover-desc");
	const urlEl = getEl<HTMLAnchorElement>("org-popover-url");

	function setIcon(src: string, alt: string) {
		if (!src) return;
		icon.style.opacity = "0";
		icon.alt = alt;
		const reveal = () => (icon.style.opacity = "1");
		icon.addEventListener("load", reveal, { once: true });
		icon.addEventListener("error", reveal, { once: true });
		icon.src = src;
		// complete=true when src is already cached; no load event fires
		if (icon.complete) reveal();
	}

	function renderPopover(d: OrgDataset) {
		title.textContent = d.name;
		roleEl.textContent = d.role;
		descEl.textContent = d.desc;
		urlEl.href = d.url || "#";
		roleEl.hidden = !d.role;
		descEl.hidden = !d.desc;
		urlEl.hidden = !d.url;
		setIcon(d.iconPath, d.name);
	}

	document.addEventListener("click", e => {
		const btn = (e.target as Element).closest<HTMLButtonElement>(".org-card");
		if (!btn) return;

		renderPopover(btn.dataset as OrgDataset);

		if (!popoverEl.matches(":popover-open")) {
			popoverEl.showPopover();
			requestAnimationFrame(() => {
				popoverEl.querySelector<HTMLButtonElement>("[popovertargetaction='hide']")?.focus();
			});
		}
	});
</script>

<style>
	#org-popover-icon {
		transition: opacity 0.15s ease;
	}

	.org-popover {
		padding: 0;
		border: none;
		background: var(--color-background);
		margin: auto;
		min-width: 320px;
		max-height: 90vh;
		overflow-y: auto;
	}

	.org-popover::backdrop {
		background-color: rgba(0, 0, 0, 0.35);
		backdrop-filter: blur(8px);
		-webkit-backdrop-filter: blur(8px);
	}

	@media (prefers-reduced-motion: reduce) {
		.org-popover::backdrop {
			backdrop-filter: none;
			-webkit-backdrop-filter: none;
		}
	}
</style>
