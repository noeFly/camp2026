---
import { Image } from "astro:assets";
import MaterialSymbolsPlayCircleOutlineRounded from "~icons/material-symbols/play-circle-outline-rounded";

import homeData from "@/data/home.json";

const { studentComment } = homeData;
const commentColorClassMap: Record<string, string> = {
	blue: "bg-blue",
	orange: "bg-orange",
	green: "bg-green",
	"dark-green": "bg-dark-green",
	"sky-blue": "bg-sky-blue",
	"soft-blue": "bg-soft-blue"
};
---

<div class="bg-background relative overflow-hidden">
	<div class="mx-auto flex w-full max-w-6xl flex-col gap-20 px-4 py-4 sm:px-6 sm:pt-32 sm:pb-16 lg:px-8">
		<h2 class="text-center text-[3rem] leading-[133%] font-bold text-balance">{studentComment.sectionTitle}</h2>
		<!-- 固定留言 -->
		<div class="relative py-8">
			<!-- 背景跑馬燈 -->
			<div class="pointer-events-none absolute inset-0 z-0 -mx-32 flex flex-col justify-between overflow-hidden opacity-15" data-student-bg-marquee data-marquee-text={studentComment.bgMarquee.text}>
			</div>
			<div class="relative z-10">
				<div class="grid grid-cols-1 gap-y-6 sm:grid-cols-2 sm:gap-x-4 md:gap-x-8 md:gap-y-10 lg:grid-cols-3 lg:gap-x-16">
					{
						studentComment.comments.map(c => (
							<div class="bg-foreground flex flex-col items-start rounded-4xl">
								<div class:list={["flex h-19 items-center gap-4 self-stretch rounded-t-4xl p-4", commentColorClassMap[c.color] ?? "bg-blue"]}>
									<Image src={studentComment.avatarSrc} alt={studentComment.avatarAlt} height="48" width="48" class="rounded-full" />
									<p class="text-[1.5rem] leading-[100%] font-bold text-white">{c.name}</p>
									<div />
								</div>
								<p class="text-background p-6 text-[1rem] leading-[133%]">{c.comment}</p>
							</div>
						))
					}
				</div>
			</div>
		</div>
	</div>
	<!-- 影片跑馬燈 -->
	<div class="marquee-container mb-16 flex w-dvw overflow-hidden">
		<div class="marquee-track flex w-max gap-4">
			<div class="flex shrink-0 gap-4">
				{
					[0, 1].map(() =>
						studentComment.video.map(v => (
							<button
								type="button"
								class="video-card bg-foreground relative aspect-video w-md cursor-pointer rounded-4xl bg-cover bg-center"
								style={`background-image: url('${v.cover}')`}
								data-url={v.url}
								aria-label={`播放 ${v.label} 影片`}
							>
								<div class="from-foreground flex h-full w-full items-center justify-center rounded-4xl bg-linear-to-t from-0% to-transparent to-30%">
									<MaterialSymbolsPlayCircleOutlineRounded class="text-background text-2xl" />
								</div>
								<p class="text-background absolute bottom-3 left-0 w-full text-center text-4xl font-bold">{v.label}</p>
							</button>
						))
					)
				}
			</div>
		</div>
	</div>

	<!-- 學員訪談 YouTube 影片 popup -->
	<dialog id="comment-dialog" class="m-auto w-full max-w-3xl rounded-4xl">
		<div class="aspect-video w-full">
			<iframe id="comment-iframe" class="h-full w-full rounded-4xl" title="YouTube video player" allow="autoplay; encrypted-media;" src="" referrerpolicy="strict-origin-when-cross-origin"></iframe>
		</div>
	</dialog>
</div>

<style>
	@keyframes marquee {
		from {
			transform: translateX(0);
		}
		to {
			transform: translateX(-50%);
		}
	}

	/* 影片跑馬燈 */
	.marquee-track {
		animation: marquee 60s linear infinite;
	}

	.marquee-container:hover .marquee-track {
		animation-play-state: paused;
	}

	/* 背景文字跑馬燈 */
	:global(.student-comment-marquee-row) {
		animation: marquee 50s linear infinite;
		width: max-content;
	}

	:global(.student-comment-marquee-text) {
		font-size: 3rem;
		font-weight: 700;
		line-height: 100%;
		white-space: nowrap;
		user-select: none;
	}
</style>

<script>
	const dialog = document.getElementById("comment-dialog") as HTMLDialogElement;
	const iframe = document.getElementById("comment-iframe") as HTMLIFrameElement;
	const bgMarquee = document.querySelector<HTMLElement>("[data-student-bg-marquee]");

	function renderBgMarqueeRows() {
		if (!bgMarquee) return;

		const text = bgMarquee.dataset.marqueeText ?? "";
		const targetRowGap = window.innerWidth < 640 ? 96 : window.innerWidth < 1024 ? 128 : 160;
		const rowCount = Math.min(24, Math.max(6, Math.ceil(bgMarquee.clientHeight / targetRowGap)));
		if (bgMarquee.dataset.rowCount === String(rowCount)) return;

		bgMarquee.dataset.rowCount = String(rowCount);
		bgMarquee.replaceChildren();

		for (let i = 0; i < rowCount; i += 1) {
			const row = document.createElement("div");
			row.className = "student-comment-marquee-row";
			row.style.marginLeft = `${(i % 3) * -8}rem`;

			const rowText = document.createElement("span");
			rowText.className = "student-comment-marquee-text";
			rowText.textContent = `${text.repeat(20)}\u00A0`;

			row.append(rowText);
			bgMarquee.append(row);
		}
	}

	if (bgMarquee) {
		renderBgMarqueeRows();
		new ResizeObserver(renderBgMarqueeRows).observe(bgMarquee);
		window.addEventListener("resize", renderBgMarqueeRows);
	}

	document.querySelectorAll<HTMLElement>(".video-card").forEach(card => {
		card.addEventListener("click", () => {
			const url = card.dataset.url;
			if (!url) return;
			iframe.src = url;
			dialog.showModal();
		});
	});

	dialog.addEventListener("click", e => {
		if (e.target === dialog) closeModal();
	});

	dialog.addEventListener("close", _ => {
		iframe.src = "";
	});

	function closeModal() {
		dialog.close();
	}
</script>
