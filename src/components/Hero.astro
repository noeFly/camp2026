---
const topics = ["資訊安全", "人工智慧", "軟體工程"];
const finalPrefix = "那就來";
const heroSubtitle = "陽明交通大學 7/8 - 7/12";
const heroTitle = "SITCON Camp 2026";
---

<section class="hero-page" aria-labelledby="hero-page-title">
  <div class="hero-page__content">
    <p class="hero-page__subtitle" data-hero-page-subtitle>{heroSubtitle}</p>
    <h1 id="hero-page-title" class="hero-page__title" data-hero-page-title>
      <span data-hero-page-title-label>{heroTitle}</span>
    </h1>
  </div>
</section>

<section data-hero-intro aria-label="SITCON Camp 2026 介紹">
  <span
    class="hero-intro__curtain hero-intro__curtain--top"
    data-hero-intro-curtain-top></span>
  <span
    class="hero-intro__curtain hero-intro__curtain--bottom"
    data-hero-intro-curtain-bottom></span>
  <div class="hero-intro__stage">
    <p class="hero-intro__question" data-hero-intro-question aria-live="polite">
      <span>想要學</span>
      <span class="hero-intro__topic-viewport">
        <span class="hero-intro__topic-track" data-hero-intro-topic-track>
          {
            topics.map((topic, index) => (
              <span
                class:list={[
                  "hero-intro__topic",
                  index === 0 && "hero-intro__topic--current",
                ]}
                data-hero-intro-topic
                aria-hidden={index === 0 ? "false" : "true"}
              >
                {topic}
              </span>
            ))
          }
        </span>
      </span>
      <span>？</span>
    </p>
    <p class="hero-intro__final" data-hero-intro-final hidden>
      <span data-hero-intro-final-prefix>{finalPrefix}</span>
      <span class="hero-intro__final-title" data-hero-intro-final-title>
        {heroTitle}
      </span>
    </p>
  </div>
</section>

<noscript>
  <style>
    [data-hero-intro] {
      display: none !important;
    }

    [data-hero-page-subtitle] {
      visibility: visible !important;
      transform: none !important;
    }
  </style>
</noscript>

<script>
  import { animate, createLayout, splitText, stagger } from "animejs";

  const intro = document.querySelector<HTMLElement>("[data-hero-intro]");
  const heroSubtitle = document.querySelector<HTMLElement>(
    "[data-hero-page-subtitle]",
  );
  const heroTitle = document.querySelector<HTMLElement>(
    "[data-hero-page-title]",
  );
  const heroTitleLabel = document.querySelector<HTMLElement>(
    "[data-hero-page-title-label]",
  );
  const question = intro?.querySelector<HTMLElement>(
    "[data-hero-intro-question]",
  );
  const final = intro?.querySelector<HTMLElement>("[data-hero-intro-final]");
  const finalPrefix = intro?.querySelector<HTMLElement>(
    "[data-hero-intro-final-prefix]",
  );
  const finalTitle = intro?.querySelector<HTMLElement>(
    "[data-hero-intro-final-title]",
  );
  const topCurtain = intro?.querySelector<HTMLElement>(
    "[data-hero-intro-curtain-top]",
  );
  const bottomCurtain = intro?.querySelector<HTMLElement>(
    "[data-hero-intro-curtain-bottom]",
  );
  const topicViewport = intro?.querySelector<HTMLElement>(
    ".hero-intro__topic-viewport",
  );
  const topicTrack = intro?.querySelector<HTMLElement>(
    "[data-hero-intro-topic-track]",
  );
  const topics = intro
    ? Array.from(intro.querySelectorAll<HTMLElement>("[data-hero-intro-topic]"))
    : [];
  const shouldSkipIntro = window.scrollY > 0;

  const wait = (duration: number) =>
    new Promise((resolve) => window.setTimeout(resolve, duration));

  const setActiveTopic = (activeIndex: number) => {
    topics.forEach((topic, index) => {
      topic.classList.toggle(
        "hero-intro__topic--current",
        index === activeIndex,
      );
      topic.setAttribute("aria-hidden", String(index !== activeIndex));
    });
  };

  const finishIntro = () => {
    document.documentElement.classList.remove("hero-intro-lock");

    if (intro) {
      intro.hidden = true;
    }

    window.dispatchEvent(new CustomEvent("hero-intro:finished"));
  };

  const skipIntro = () => {
    if (intro) {
      intro.hidden = true;
    }

    if (heroSubtitle) {
      heroSubtitle.classList.add("is-visible");
      heroSubtitle.style.transform = "none";
    }

    window.dispatchEvent(new CustomEvent("hero-intro:finished"));
  };

  const revealHeroSubtitle = async (prefersReducedMotion: boolean) => {
    if (!heroSubtitle) {
      return;
    }

    heroSubtitle.classList.add("is-visible");

    if (prefersReducedMotion) {
      heroSubtitle.style.transform = "none";
      return;
    }

    const { chars } = splitText(heroSubtitle, {
      chars: { class: "hero-page__subtitle-char", wrap: "clip" },
      accessible: true,
    });

    await animate(chars, {
      y: ["85%", "-8%", "0%"],
      duration: 620,
      ease: "out(3)",
      delay: stagger(28),
    }).then();
  };

  const bounceQuestion = async () => {
    if (!question) {
      return;
    }

    await animate(question, {
      scale: [
        { to: 1.025, duration: 140, ease: "outQuad" },
        { to: 1, duration: 260, ease: "outBounce" },
      ],
    }).then();
  };

  const slideToTopic = async (index: number) => {
    if (!topicTrack || !topicViewport) {
      return;
    }

    const rowHeight = topicViewport.getBoundingClientRect().height;
    const targetY = -index * rowHeight;

    await animate(topicTrack, {
      keyframes: [
        {
          translateY: `${targetY - rowHeight * 0.1}px`,
          duration: 280,
          ease: "outQuint",
        },
        {
          translateY: `${targetY}px`,
          duration: 150,
          ease: "outBack(1.9)",
        },
      ],
    }).then();
  };

  const showFinal = async (prefersReducedMotion: boolean) => {
    if (!question || !final) {
      return;
    }

    question.hidden = true;
    final.hidden = false;

    if (prefersReducedMotion) {
      return;
    }

    final.style.transform = "scale(1.85)";

    await animate(final, {
      scale: [
        { to: 0.96, duration: 280, ease: "outQuint" },
        { to: 1, duration: 140, ease: "outBack(1.7)" },
      ],
    }).then();

    final.style.transform = "";
  };

  const openIntroToHero = async (prefersReducedMotion: boolean) => {
    if (!intro || !heroTitle || !finalTitle || !topCurtain || !bottomCurtain) {
      return;
    }

    if (prefersReducedMotion) {
      return;
    }

    await document.fonts.ready;

    const layout = createLayout(document.body, {
      children: "[data-hero-intro-final-title]",
      duration: 720,
      ease: "inOutCubic",
      swapAt: { opacity: 1 },
    });

    await Promise.all([
      layout
        .update(() => {
          if (finalPrefix) {
            finalPrefix.hidden = true;
          }

          if (heroTitleLabel) {
            heroTitleLabel.hidden = true;
          }

          finalTitle.classList.add("hero-page__title-label");
          heroTitle.append(finalTitle);
        })
        .then(),
      animate(topCurtain, {
        translateY: "-100%",
        duration: 720,
        ease: "inOutCubic",
      }).then(),
      animate(bottomCurtain, {
        translateY: "100%",
        duration: 720,
        ease: "inOutCubic",
      }).then(),
    ]);
  };

  if (
    intro &&
    question &&
    final &&
    topicViewport &&
    topicTrack &&
    topics.length > 0
  ) {
    if (shouldSkipIntro) {
      skipIntro();
    } else {
    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;

    document.documentElement.classList.add("hero-intro-lock");

    if (!prefersReducedMotion) {
      await wait(180);
      await bounceQuestion();
    }

    for (let index = 1; index < topics.length; index += 1) {
      await wait(index === 1 && !prefersReducedMotion ? 150 : 260);

      if (prefersReducedMotion) {
        const rowHeight = topicViewport.getBoundingClientRect().height;
        topicTrack.style.transform = `translateY(${-index * rowHeight}px)`;
      } else {
        await slideToTopic(index);
      }

      setActiveTopic(index);
    }

    await wait(300);
    await showFinal(prefersReducedMotion);
    await wait(150);
    await openIntroToHero(prefersReducedMotion);
    finishIntro();
    await revealHeroSubtitle(prefersReducedMotion);
    }
  }
</script>

<style>
  .hero-page {
    position: relative;
    min-height: 100svh;
    overflow: hidden;
    background: var(--color-background);
    color: var(--color-foreground);
  }

  .hero-page__content {
    position: absolute;
    inset-inline-start: clamp(1rem, 5vw, 5rem);
    inset-block-end: clamp(1.5rem, 7vw, 6rem);
    z-index: 2;
    display: grid;
    gap: clamp(0.35rem, 1.2vw, 0.9rem);
  }

  .hero-page__subtitle {
    margin: 0;
    font-size: clamp(1.125rem, 2.8vw, 2.25rem);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: 0;
    visibility: hidden;
    transform-origin: left center;
  }

  .hero-page__subtitle.is-visible {
    visibility: visible;
  }

  .hero-page__title {
    margin: 0;
    color: var(--color-green);
    white-space: nowrap;
    font-size: clamp(1.75rem, 7.5vw, 6rem);
    font-weight: 800;
    line-height: 0.9;
    letter-spacing: 0;
  }

  :global(html.hero-intro-lock),
  :global(html.hero-intro-lock body) {
    overflow: hidden;
  }

  :global(html.hero-intro-lock) [data-hero-page-title-label] {
    visibility: hidden;
  }

  [data-hero-intro] {
    position: fixed;
    inset: 0;
    z-index: 10000;
    display: grid;
    place-items: center;
    overflow: hidden;
    overscroll-behavior: contain;
    touch-action: none;
    color: var(--color-foreground);
  }

  .hero-intro__curtain {
    position: absolute;
    inset-inline: 0;
    z-index: 0;
    height: 50%;
    background: var(--color-background);
    will-change: transform;
  }

  .hero-intro__curtain--top {
    inset-block-start: 0;
  }

  .hero-intro__curtain--bottom {
    inset-block-end: 0;
  }

  [data-hero-intro][hidden],
  .hero-intro__question[hidden],
  .hero-intro__final[hidden] {
    display: none;
  }

  .hero-intro__stage {
    position: relative;
    z-index: 1;
    width: min(calc(100vw - 2rem), 1100px);
    text-align: center;
  }

  .hero-intro__question,
  .hero-intro__final {
    display: grid;
    align-items: center;
    justify-content: center;
    margin: 0;
    white-space: nowrap;
    font-size: clamp(1rem, 5.6vw, 5rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: 0;
    transform-origin: center;
  }

  .hero-intro__question {
    grid-template-columns: auto 4.2em auto;
    column-gap: 0.18em;
  }

  .hero-intro__final {
    grid-auto-flow: column;
    column-gap: 0.18em;
  }

  .hero-intro__final-title {
    display: inline-grid;
    place-items: center;
    color: var(--color-green);
    transform-origin: center;
    will-change: transform;
  }

  .hero-intro__topic-viewport {
    display: block;
    height: 1.1em;
    overflow: hidden;
    color: var(--color-primary-blue);
  }

  .hero-intro__topic-track {
    display: flex;
    flex-direction: column;
    height: 100%;
    transform: translateY(0px);
    will-change: transform;
  }

  .hero-intro__topic {
    display: grid;
    flex: 0 0 100%;
    place-items: center;
    height: 100%;
    line-height: 1.1;
    white-space: nowrap;
  }

  @media (max-width: 520px) {
    .hero-page__content {
      inset-inline-start: 1rem;
      inset-block-end: 2rem;
    }

    .hero-intro__stage {
      width: calc(100vw - 1rem);
    }
  }
</style>
