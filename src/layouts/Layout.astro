---
import '../styles/global.css';

interface Props {
	title?: string;
}

const { title = 'SITCON Camp 2026' } = Astro.props;
const baseUrl = import.meta.env.BASE_URL.endsWith('/')
	? import.meta.env.BASE_URL
	: `${import.meta.env.BASE_URL}/`;
const publicAsset = (path: string) => `${baseUrl}${path.replace(/^\/+/, '')}`;
---

<!doctype html>

<html lang="zh-Hant">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href={publicAsset('favicon.svg')} />
		<link rel="icon" href={publicAsset('favicon.ico')} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
