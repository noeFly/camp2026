		link: 'https://forms.gle/TFUEkkvjR1po38B2A',
	},
	{
		name: '設計組',
		description: '負責主視覺、網頁、社群出圖與整體視覺。',
		deadline: '招募中',
		link: 'https://forms.gle/ztny7QQ3vX6yvM4U8',
	},
	{
		name: '開發組',
		description: '開發 Camp 官網與營期間會用到的活動網站。',
		deadline: '4/24 截止',
		link: 'https://forms.gle/3AZ9MFu4nA1uCQheA',
	},
	{
		name: '庶務組',
		description: '負責學員與工作人員的吃住與現場後勤。',
		deadline: '4/18 截止',
		link: 'https://t.me/agong1021',
	},
];

const faqItems = [
	{
		question: '沒有辦過活動，也可以加入嗎？',
		answer: '可以。很多組別都歡迎願意學習、願意一起做事的人加入，不需要一開始就很熟。',
	},
	{
		question: '不會寫程式，也能加入嗎？',
		answer: '可以。除了開發組，還有行政、編輯、設計、隊輔、庶務、課程活動等不同角色。',
	},
	{
		question: '工作人員一定要上營嗎？',
		answer: '不一定，每組需求不同。隊輔與部分開發、現場組別會需要上營，細節請看各組招募資訊。',
	},
	{
		question: '學員報名開始了嗎？',
		answer: '還沒。學員報名開始時間尚未公布，屆時會再公告相關資訊。',
	},
];

const staffMembers = [
	{
		name: 'Windless',
		role: '總召',
		avatar:
			'https://gravatar.com/avatar/5b168d8b83a4f506cf9be7b9b86b7ffc2b7a8dee29e5f6c82f9720764fc05f4d?s=200&d=identicon',
	},
	{
		name: 'Fearnot',
		role: '副召',
		avatar:
			'https://gravatar.com/avatar/4e2c4d83a0da00261fc8fe88cfaa70d8892fcb144feb4149eb926b6f7aef597d?s=200&d=identicon',
	},
	{
		name: 'Ya',
		role: '行政組 組長',
		avatar:
			'https://gravatar.com/avatar/3dc682683048afd1630ae4329b7269a2dc9fa301480a8abe6e974893eba6683d?s=200&d=identicon',
	},
	{
		name: 'Wolf Yuan',
		role: '隊輔組 組長',
		avatar:
			'https://gravatar.com/avatar/3d77e79456c983f048d74ea2739e8acbcc222d882bf294401209e00435c6b2d7?s=200&d=identicon',
	},
	{
		name: 'Mina',
		role: '編輯組 組長',
		avatar:
			'https://gravatar.com/avatar/dbfbb99d57882e065243ab549d00d63eabb2dfa8e5ba7d9e7abb1ed0daa2c3f4?s=200&d=identicon',
	},
	{
		name: 'Nathan',
		role: '課程活動組 組長',
		avatar:
			'https://gravatar.com/avatar/e087ca958a3115405b32e62072ff801b5dfcb4179607a1c56f20df88043e16ab?s=200&d=identicon',
	},
	{
		name: 'Yoru',
		role: '開發組 組長',
		avatar:
			'https://gravatar.com/avatar/cdf78bfb55f7be52400da72e2b780ffc62af848476b998f80bbf287c67b231a7?s=200&d=identicon',
	},
	{
		name: '康喔',
		role: '紀錄組 組長',
		avatar:
			'https://gravatar.com/avatar/08b25778f9a9ca3f2591b4e859be426dbd075608d763daf4fdd244d48eb26f13?s=200&d=identicon',
	},
	{
		name: '阿公',
		role: '庶務組 組長',
		avatar:
			'https://gravatar.com/avatar/196e64709935c454b821b5de526e48cf790dbd78a0606642405a35ae592e63d2?s=200&d=identicon',
	},
	{
		name: 'Lindy',
		role: '財務組 組長',
		avatar:
			'https://gravatar.com/avatar/6c6c3bed1c257ebdba662b12111724bc96ff804c41936045954acc6b60dc81b5?s=200&d=identicon',
	},
];

const vlog = {
	title: '2025 Vlog',
	url: 'https://www.youtube.com/watch?v=CansA62TYXY',
	thumbnail: 'https://img.youtube.com/vi/CansA62TYXY/maxresdefault.jpg',
};
---

<Layout title="SITCON Camp 2026">
	<div class="bg-paper text-ink">
		<header class="border-b border-line bg-paper/95">
			<div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-6 py-4">
				<a href="#top" class="inline-flex">
					<img src="/sitcon-camp.svg" alt="SITCON Camp" class="h-7 w-auto invert md:h-8" />
				</a>
				<nav class="hidden gap-6 text-sm md:flex">
					<a href="#about" class="hover:text-rust">關於</a>
					<a href="#recruit" class="hover:text-rust">加入工作人員</a>
					<a href="#timeline" class="hover:text-rust">時程</a>
					<a href="#team" class="hover:text-rust">工作人員</a>
					<a href="#faq" class="hover:text-rust">FAQ</a>
				</nav>
				<a
					href="https://i.sitcon.org/camp-recruit"
					target="_blank"
					rel="noreferrer"
					class="border border-line bg-rust px-4 py-2 text-sm font-medium text-cream hover:bg-rust-strong"
				>
					立即跳坑
				</a>
			</div>
		</header>

		<main id="top">
			<section class="border-b border-line bg-sand/15">
				<div class="mx-auto max-w-6xl px-6 py-20 md:py-28">
					<p class="mb-4 text-sm tracking-[0.2em] text-rust">第十屆 / 十週年</p>
					<h1 class="max-w-4xl text-5xl font-semibold leading-tight md:text-7xl">
						SITCON Camp 2026
					</h1>
					<p class="mt-6 max-w-2xl text-lg leading-8 text-ink/90">
						今夏，我們回來了。學生辦的、給學生玩的資訊科技夏令營，工作人員招募中。
					</p>
					<div class="mt-8 flex flex-wrap gap-3 text-sm">
						<div class="border border-line bg-cream px-3 py-2">7/8 - 7/12</div>
						<div class="border border-line bg-cream px-3 py-2">國立陽明交通大學</div>
						<div class="border border-line bg-cream px-3 py-2">五天四夜</div>
					</div>
					<div class="mt-10 flex flex-wrap gap-4">
						<a
							href="https://i.sitcon.org/camp-recruit"
							target="_blank"
							rel="noreferrer"
							class="bg-rust px-5 py-3 text-cream hover:bg-rust-strong"
						>
							工人跳坑表單
						</a>
						<a href="#about" class="border border-line px-5 py-3 hover:bg-cream">了解更多</a>
					</div>
				</div>
			</section>

			<section id="about" class="border-b border-line">
				<div class="mx-auto grid max-w-6xl gap-12 px-6 py-16 md:grid-cols-2">
					<div>
						<p class="mb-3 text-sm tracking-[0.2em] text-rust">ABOUT</p>
						<h2 class="text-3xl font-semibold">什麼是 SITCON Camp？</h2>
					</div>
					<div class="space-y-5 text-base leading-8 text-ink/90">
						<p>
							SITCON Camp 是一個由學生辦、給學生玩的資訊科技夏令營。不是培訓班，也不是補習班，而是一群熱愛資訊的人聚在一起，一起學、一起做、一起搞事的地方。
						</p>
						<p>
							2026 年是第十屆。這次落腳國立陽明交通大學，從 7 月 8 日到 7 月 12 日，五天四夜。
						</p>
						<p>
							課程主題仍在籌備中，工作人員招募已經開始。想一起把這屆 Camp 做出來的人，現在就可以加入。
						</p>
					</div>
				</div>
			</section>

			<section id="recruit" class="border-b border-line bg-cream/60">
				<div class="mx-auto max-w-6xl px-6 py-16">
					<div class="grid gap-8 md:grid-cols-[1fr_2fr] md:items-start">
						<div>
							<p class="mb-3 text-sm tracking-[0.2em] text-rust">RECRUIT</p>
							<h2 class="text-3xl font-semibold">一起把這屆 Camp 做出來</h2>
						</div>
						<div class="space-y-5 text-base leading-8 text-ink/90">
							<p>
								每個活動的成功，皆仰賴在幕後默默付出的工作人員。如果你也想參與活動的籌備，和一群實力堅強且有想法的人一起完成這件事，歡迎依照自己的專長與興趣加入我們。
							</p>
							<p>
								各組招募資訊、截止日期與報名入口已整理在下面；完整職缺說明可以直接看招募文件。
							</p>
							<div class="flex flex-wrap gap-4 pt-2">
								<a
									href="https://i.sitcon.org/camp-recruit"
									target="_blank"
									rel="noreferrer"
									class="bg-rust px-5 py-3 text-cream hover:bg-rust-strong"
								>
									立即跳坑
								</a>
								<a
									href="https://hackmd.io/@SITCON/2026-camp-recruit"
									target="_blank"
									rel="noreferrer"
									class="border border-line px-5 py-3 hover:bg-paper"
								>
									招募說明文件
								</a>
							</div>
						</div>
					</div>

					<div class="mt-12 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
						{
							recruitTeams.map((team) => (
								<article class="border border-line bg-paper p-5">
									<div class="flex items-start justify-between gap-4">
										<h3 class="text-xl font-semibold">{team.name}</h3>
										<span class="text-sm text-rust">{team.deadline}</span>
									</div>
									<p class="mt-4 text-sm leading-7 text-ink/90">{team.description}</p>
									<a
										href={team.link}
										target="_blank"
										rel="noreferrer"
										class="mt-6 inline-block border border-line px-4 py-2 text-sm hover:bg-cream"
									>
										查看入口
									</a>
								</article>
							))
						}
					</div>
				</div>
			</section>

			<section id="timeline" class="border-b border-line">
				<div class="mx-auto max-w-6xl px-6 py-16">
					<p class="mb-3 text-sm tracking-[0.2em] text-rust">TIMELINE</p>
					<h2 class="text-3xl font-semibold">重要時程</h2>
					<div class="mt-10 grid gap-px border border-line bg-line md:grid-cols-2">
						<div class="bg-cream p-5">
							<p class="text-sm">2026 / 04 / 01</p>
							<p class="mt-2 text-lg font-medium">一切從這裡開始</p>
						</div>
						<div class="bg-cream p-5">
							<p class="text-sm">2026 / 04 / 01</p>
							<p class="mt-2 text-lg font-medium">工人跳坑開始</p>
						</div>
						<div class="bg-cream p-5">
							<p class="text-sm">TBD</p>
							<p class="mt-2 text-lg font-medium">工人跳坑截止</p>
						</div>
						<div class="bg-cream p-5">
							<p class="text-sm">TBD</p>
							<p class="mt-2 text-lg font-medium">線上籌備開跑</p>
						</div>
						<div class="bg-cream p-5">
							<p class="text-sm">TBD</p>
							<p class="mt-2 text-lg font-medium">工人相見歡</p>
						</div>
						<div class="bg-cream p-5">
							<p class="text-sm">TBD</p>
							<p class="mt-2 text-lg font-medium">學員報名開始</p>
						</div>
						<div class="bg-cream p-5 md:col-span-2">
							<p class="text-sm">2026 / 07 / 08 - 07 / 12</p>
							<p class="mt-2 text-lg font-medium">出發</p>
						</div>
					</div>
				</div>
			</section>

			<section id="team" class="border-b border-line bg-sand/10">
				<div class="mx-auto max-w-6xl px-6 py-16">
					<p class="mb-3 text-sm tracking-[0.2em] text-rust">TEAM</p>
					<h2 class="text-3xl font-semibold">工作人員</h2>
					<p class="mt-4 max-w-2xl text-base leading-8 text-ink/90">
						因為有這群人在背後搞事，才有今年的五天四夜。
					</p>
					<div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
						{
							staffMembers.map((member) => (
								<article class="border border-line bg-paper p-5">
									{member.avatar && (
										<img
											src={member.avatar}
											alt={member.name}
											class="mb-4 h-16 w-16 border border-line object-cover"
											loading="lazy"
										/>
									)}
									<p class="text-xl font-semibold">{member.name}</p>
									<p class="mt-2 text-sm leading-7 text-ink/80">{member.role}</p>
								</article>
							))
						}
					</div>
				</div>
			</section>

			<section class="border-b border-line">
				<div class="mx-auto max-w-6xl px-6 py-16">
					<div class="grid gap-8 border border-line bg-cream md:grid-cols-[1fr_1.4fr]">
						<div class="flex flex-col justify-between p-8 md:p-10">
							<div>
								<p class="mb-3 text-sm tracking-[0.2em] text-rust">VLOG</p>
								<h2 class="text-3xl font-semibold">先看看去年的 Camp</h2>
								<p class="mt-5 max-w-lg text-base leading-8 text-ink/90">
									如果你想知道 SITCON Camp 的五天四夜到底長什麼樣子，這支影片會比任何一段介紹都更直接。
								</p>
								<p class="mt-4 max-w-lg text-base leading-8 text-ink/90">
									課程、黑客松、社群交流，還有一群把事情做出來的人，都在這裡。
								</p>
							</div>
							<div class="mt-8 flex flex-wrap gap-4">
								<a
									href={vlog.url}
									target="_blank"
									rel="noreferrer"
									class="bg-rust px-5 py-3 text-cream hover:bg-rust-strong"
								>
									觀看 2025 Vlog
								</a>
							</div>
						</div>
						<a
							href={vlog.url}
							target="_blank"
							rel="noreferrer"
							class="group relative block min-h-[320px] overflow-hidden border-t border-line md:min-h-[420px] md:border-t-0 md:border-l"
						>
							<img
								src={vlog.thumbnail}
								alt={vlog.title}
								class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.02]"
								loading="lazy"
							/>
							<div class="absolute inset-0 bg-gradient-to-t from-ink/70 via-ink/15 to-transparent"></div>
							<div class="absolute inset-x-0 bottom-0 flex items-end justify-between gap-4 p-6 text-cream md:p-8">
								<div>
									<p class="text-sm tracking-[0.2em] text-sand">YOUTUBE</p>
									<p class="mt-2 text-2xl font-semibold">{vlog.title}</p>
								</div>
								<div class="flex h-14 w-14 items-center justify-center rounded-full border border-cream bg-ink/40 text-lg backdrop-blur-sm">
									▶
								</div>
							</div>
						</a>
					</div>
				</div>
			</section>

			<section class="border-b border-line">
				<div class="mx-auto grid max-w-6xl gap-12 px-6 py-16 md:grid-cols-2">
					<div>
						<p class="mb-3 text-sm tracking-[0.2em] text-rust">FOR STUDENTS</p>
						<h2 class="text-3xl font-semibold">想當學員的人</h2>
					</div>
					<div class="space-y-5 text-base leading-8 text-ink/90">
						<p>
							學員報名尚未開始，相關資訊會在之後公告。
						</p>
						<p>
							如果你想先了解 SITCON Camp，可以先看看去年的網站和回顧影片，或追蹤 SITCON 社群。
						</p>
						<div class="flex flex-wrap gap-4 pt-2">
							<a href="https://sitcon.camp/2025/" target="_blank" rel="noreferrer" class="border border-line px-5 py-3 hover:bg-cream">
								看 2025 官網
							</a>
							<a href="https://sitcon.org/ig" target="_blank" rel="noreferrer" class="border border-line px-5 py-3 hover:bg-cream">
								追蹤最新消息
							</a>
						</div>
					</div>
				</div>
			</section>

			<section class="border-b border-line bg-cream/60">
				<div class="mx-auto max-w-6xl px-6 py-16">
					<p class="mb-3 text-sm tracking-[0.2em] text-rust">PAST YEARS</p>
					<h2 class="text-3xl font-semibold">歷屆成果</h2>
					<div class="mt-10 grid gap-4 md:grid-cols-3">
						<div class="border border-line bg-paper p-5">
							<p class="text-4xl font-semibold">10</p>
							<p class="mt-2 text-sm leading-7 text-ink/90">2026 是第十屆，也是十週年。</p>
						</div>
						<div class="border border-line bg-paper p-5">
							<p class="text-4xl font-semibold">5D4N</p>
							<p class="mt-2 text-sm leading-7 text-ink/90">五天四夜，課程、實作、黑客松與社群交流一起發生。</p>
						</div>
						<div class="border border-line bg-paper p-5">
							<p class="text-4xl font-semibold">2014-</p>
							<p class="mt-2 text-sm leading-7 text-ink/90">這不是第一次，我們已經辦了很多年。</p>
						</div>
					</div>
					<div class="mt-8 flex flex-wrap gap-4">
						<a href="https://sitcon.camp/2025/" target="_blank" rel="noreferrer" class="border border-line px-4 py-2 text-sm hover:bg-paper">2025 官網</a>
						<a href="https://sitcon.camp/2024/" target="_blank" rel="noreferrer" class="border border-line px-4 py-2 text-sm hover:bg-paper">2024 官網</a>
						<a href="https://youtu.be/CansA62TYXY?si=kxK2kscZecsTSdRv" target="_blank" rel="noreferrer" class="border border-line px-4 py-2 text-sm hover:bg-paper">2025 Vlog</a>
						<a href="https://www.youtube.com/watch?v=b7r7DiEWsvA" target="_blank" rel="noreferrer" class="border border-line px-4 py-2 text-sm hover:bg-paper">2024 Vlog</a>
					</div>
				</div>
			</section>

			<section id="faq" class="border-b border-line">
				<div class="mx-auto max-w-6xl px-6 py-16">
					<p class="mb-3 text-sm tracking-[0.2em] text-rust">FAQ</p>
					<h2 class="text-3xl font-semibold">常見問題</h2>
					<div class="mt-10 space-y-4">
						{
							faqItems.map((item) => (
								<details class="border border-line bg-paper p-5">
									<summary class="cursor-pointer text-lg font-medium">{item.question}</summary>
									<p class="mt-4 max-w-3xl text-sm leading-7 text-ink/90">{item.answer}</p>
								</details>
							))
						}
					</div>
				</div>
			</section>

		</main>

		<footer class="mx-auto max-w-6xl px-6 py-10 text-sm leading-7 text-ink/90">
			<div class="flex flex-wrap gap-x-6 gap-y-2">
				<a href="https://i.sitcon.org/camp-recruit" target="_blank" rel="noreferrer" class="hover:text-rust">工人招募表單</a>
				<a href="https://hackmd.io/@SITCON/2026-camp-recruit" target="_blank" rel="noreferrer" class="hover:text-rust">招募說明文件</a>
